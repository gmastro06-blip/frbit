# ── OBS WebSocket ────────────────────────────────────────────────────────────
# Password configured in OBS → Tools → WebSocket Server Settings.
# Leave empty if no password is set.
OBS_WS_PASSWORD=

# ── Web Dashboard ─────────────────────────────────────────────────────────────
# Bearer token required to access the HTTP dashboard and WebSocket feed.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Leaving this empty disables authentication (not recommended).
DASHBOARD_TOKEN=

# ── Alert system (Discord / Telegram) ─────────────────────────────────────────
# Read automatically by AlertConfig when alert_enabled=true in session config.
# These take effect when the corresponding session config fields are empty.

# Discord Incoming Webhook URL (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=

# Telegram bot token obtained from @BotFather.
TELEGRAM_BOT_TOKEN=

# Telegram chat ID where alerts are sent (numeric, e.g. -100123456789 for a group).
TELEGRAM_CHAT_ID=
